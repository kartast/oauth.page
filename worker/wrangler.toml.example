# Copy this file to `wrangler.toml` and fill in your own resource IDs.
#   cp wrangler.toml.example wrangler.toml
# `wrangler.toml` is gitignored because it is unique to your Cloudflare account.
# Create resources with the commands in README.md → "Deploy to Cloudflare",
# then paste the printed IDs below.

name = "oauth-page-worker"
main = "src/index.ts"
compatibility_date = "2024-06-20"
compatibility_flags = ["nodejs_compat"]

[vars]
APP_URL = "https://app.example.com"
DASHBOARD_URL = "https://your-dashboard.pages.dev"
BETA_ONE_TIME_LINKS = "true" # easy launch toggle: set to "false"
# Optional: visitor logging store. Leave unset to disable.
# SUPABASE_URL = "https://<your-project>.supabase.co"

# Set these as secrets via `wrangler secret put <NAME>` — never commit them:
#   GITHUB_CLIENT_ID
#   GITHUB_CLIENT_SECRET
#   GOOGLE_CLIENT_ID
#   GOOGLE_CLIENT_SECRET
#   JWT_SECRET
#   RESEND_API_KEY
#   SUPABASE_SERVICE_KEY

[[d1_databases]]
binding = "DB"
database_name = "oauth-page-db"
database_id = "<YOUR_D1_DATABASE_ID>"   # wrangler d1 create oauth-page-db
migrations_dir = "drizzle"

[[kv_namespaces]]
binding = "KV"
id = "<YOUR_KV_NAMESPACE_ID>"           # wrangler kv namespace create KV

[[r2_buckets]]
binding = "STORAGE"
bucket_name = "oauthpage-sites"          # wrangler r2 bucket create oauthpage-sites

[browser]
binding = "BROWSER"

# Vanity routing — point at your own zone, or delete to use *.workers.dev
[[routes]]
pattern = "*.example.com/*"
zone_name = "example.com"

[[routes]]
pattern = "example.com/*"
zone_name = "example.com"

# Screenshot queue — decouples deploys from browser rendering
[[queues.producers]]
queue = "screenshot-jobs"
binding = "SCREENSHOT_QUEUE"

[[queues.consumers]]
queue = "screenshot-jobs"
max_batch_size = 1
max_retries = 3
dead_letter_queue = "screenshot-dlq"
max_batch_timeout = 0
max_concurrency = 5

# ─── Staging Environment ───
[env.staging]
workers_dev = true
name = "oauth-page-worker-staging"
routes = []

[env.staging.vars]
APP_URL = "https://oauth-page-worker-staging.<your-subdomain>.workers.dev"
DASHBOARD_URL = "https://your-dashboard-staging.pages.dev"
BETA_ONE_TIME_LINKS = "true"
# SUPABASE_URL = "https://<your-project>.supabase.co"

[[env.staging.d1_databases]]
binding = "DB"
database_name = "oauth-page-db-staging"
database_id = "<YOUR_STAGING_D1_DATABASE_ID>"
migrations_dir = "drizzle"

[[env.staging.kv_namespaces]]
binding = "KV"
id = "<YOUR_STAGING_KV_NAMESPACE_ID>"

[[env.staging.r2_buckets]]
binding = "STORAGE"
bucket_name = "oauthpage-sites-staging"

[env.staging.browser]
binding = "BROWSER"

[[env.staging.queues.producers]]
queue = "screenshot-jobs-stg"
binding = "SCREENSHOT_QUEUE"

[[env.staging.queues.consumers]]
queue = "screenshot-jobs-stg"
max_batch_size = 1
max_retries = 3
dead_letter_queue = "screenshot-dlq-stg"
max_batch_timeout = 0
max_concurrency = 5
